# ============================================================================
# Smart AI Study Assistant - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your values
# See README.md for detailed configuration instructions

# ----------------------------------------------------------------------------
# Node Environment
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# AI Service Configuration
# ----------------------------------------------------------------------------
# Provider: "openai" or "anthropic"
AI_PROVIDER=openai
# API Key from your AI provider
AI_API_KEY=your-api-key-here
# Model: "gpt-4" for OpenAI or "claude-3-sonnet-20240229" for Anthropic
AI_MODEL=gpt-4

# Token Limits (optional, defaults shown)
AI_MAX_INPUT_TOKENS=4000
AI_MAX_OUTPUT_TOKENS_SUMMARY=500
AI_MAX_OUTPUT_TOKENS_QUIZ=1000
AI_REQUEST_TIMEOUT=15000

# ----------------------------------------------------------------------------
# Storage Configuration
# ----------------------------------------------------------------------------
# Mode: "localStorage" (client-side) or "database" (server-side)
STORAGE_MODE=localStorage
# Database URL (required if STORAGE_MODE=database)
# DATABASE_URL=postgresql://user:password@localhost:5432/study_assistant

# ----------------------------------------------------------------------------
# Authentication Configuration (required if STORAGE_MODE=database)
# ----------------------------------------------------------------------------
AUTH_REQUIRED=false
# JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRY=86400

# ----------------------------------------------------------------------------
# Rate Limiting Configuration
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_HOUR=20

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL=86400
CACHE_MAX_ENTRIES=1000

# ----------------------------------------------------------------------------
# Analytics Configuration
# ----------------------------------------------------------------------------
VERCEL_ANALYTICS_ENABLED=true

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins, or "*" for all
ALLOWED_ORIGINS=*

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Level: "debug", "info", "warn", or "error"
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Monitoring Configuration (optional)
# ----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
